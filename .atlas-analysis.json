  "keyFeatures": [
    "Dual interface with GUI desktop and CLI terminal modes",
    "Dynamic window management with draggable, resizable windows",
    "Interactive terminal with Unix-like commands and file system",
    "Real-time Spotify integration showing now playing and playlists",
    "Custom wallpaper system with dynamic background changes",
    "RAG-powered chatbot backend using Azure OpenAI and pgvector",
    "PDF viewer for embedded document display",
    "Neumorphic design with smooth Framer Motion animations",
    "Firebase integration for data persistence"
  ],
  "publicApiSurface": [
    "Terminal commands: help, ls, cd, cat, mkdir, touch, rm, experience, github",
    "Window components: AboutWindow, ProjectsWindow, ExperienceWindow, SkillsWindow, SpotifyWindow, BooksWindow, BrowserWindow, SettingsWindow, GamesWindow, PdfWindow, PranavChatWindow",
    "UI components: FloatingDock, DesktopIcons, WindowWrapper, ButtonToggle, Quote",
    "Spotify API routes: /api/spotify/now-playing, /api/spotify/playlists, /api/spotify/recently-played, /api/spotify/top-tracks, /api/spotify/top-artists",
    "RAG Chatbot API: POST /chat, POST /admin/documents, GET /admin/documents, GET /admin/documents/:id, DELETE /admin/documents/:id",
    "Contexts: WindowContext for window state management",
    "Utilities: spotify.ts, firebase.ts, math.ts, utils.ts"
  ]
